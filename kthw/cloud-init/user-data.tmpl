#cloud-config
# Cloud-init NoCloud user-data template.
# Placeholders @HOSTNAME@ and @SSHKEY@ are substituted by provision.sh.

hostname: @HOSTNAME@
fqdn: @HOSTNAME@.kubernetes.local
# Don't let cloud-init manage /etc/hosts — we add KTHW cluster entries
# (server-N, node-N, lb-0) and want them to survive reboots.
manage_etc_hosts: false
preserve_hostname: false

users:
  - name: misha
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: [sudo, adm]
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - @SSHKEY@

ssh_pwauth: false
# Allow key-based root SSH (Debian's sshd default is prohibit-password).
# KTHW v1.32 commands assume `ssh root@<host>` works everywhere.
disable_root: false

# Force IPv4 for apt and glibc resolvers. The libvirt 'kthw' network is
# IPv4-only, but DNS returns AAAA records (deb.debian.org is dual-stack);
# without these, apt picks IPv6, opens a socket with no route, and stalls.
# write_files runs in the 'config' stage, before package-update in 'final'.
write_files:
  - path: /etc/apt/apt.conf.d/99-force-ipv4
    permissions: '0644'
    content: |
      Acquire::ForceIPv4 "true";
  - path: /etc/gai.conf
    permissions: '0644'
    content: |
      precedence ::ffff:0:0/96  100
  - path: /root/.ssh/authorized_keys
    permissions: '0600'
    owner: root:root
    content: |
      @SSHKEY@

package_update: true
package_upgrade: false
packages:
  - openssh-server
  - curl
  - wget
  - vim-nox
  - tmux
  - bash-completion
  - ca-certificates
  - gnupg
  - lsb-release
  - netcat-openbsd
  - dnsutils

# Drop a marker so we can tell if cloud-init finished without journalctl-spelunking.
runcmd:
  # write_files creates /root/.ssh at 0755; sshd needs 0700 or it ignores the file.
  - [ chmod, '0700', /root/.ssh ]
  - [ sh, -c, 'echo "cloud-init done at $(date -Iseconds)" > /etc/kthw-ready' ]
